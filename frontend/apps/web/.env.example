# Log level for frontend logging
# Options: trace, debug, info, warn, error
# Default: debug in development, error in production
VITE_LOG_LEVEL=debug

# API Backend URL (optional)
# If set, the frontend will make API requests directly to this URL instead of using the /api proxy
# Examples:
#   - http://localhost:8000  (local development with external backend)
#   - https://api.example.com  (production)
#   - Leave empty to use /api proxy (default, works for Vite dev server)
VITE_API_URL=
