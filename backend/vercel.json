{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../frontend && pnpm install && pnpm build",
  "outputDirectory": "../frontend/apps/web/dist",
  "installCommand": "uv sync",
  "framework": null,
  "regions": ["iad1"],
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-feeds",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 * * * *"
    }
  ]
}
